# ─────────────────────────────────────────────
# CoffeeMonitor Colombia - Variables de Entorno
# ─────────────────────────────────────────────
# Copiar este archivo como .env y ajustar los valores.
# Estos valores son opcionales; el sistema funciona sin ellos.

# Socrata App Token (opcional, aumenta límite de requests a datos.gov.co)
# Obtener gratis en: https://www.datos.gov.co/profile/edit/developer_settings
# SOCRATA_APP_TOKEN=tu_token_aqui

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Ruta alternativa para la base de datos
# DB_PATH=./data/coffeemonitor.db
